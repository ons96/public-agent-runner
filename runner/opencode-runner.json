{
  "$schema": "https://opencode.ai/config.json",
  "permissions": {
    "*": "allow"
  },
  "provider": {
    "groq": {
      "name": "Groq",
      "options": {
        "apiKey": "${GROQ_API_KEY}"
      }
    },
    "openrouter": {
      "name": "OpenRouter",
      "options": {
        "apiKey": "${OPENROUTER_API_KEY}"
      }
    }
  },
  "model": "groq/llama-3.3-70b-versatile",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "groq/llama-3.3-70b-versatile",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "openrouter/deepseek-v4-flash:free",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "model_fallback": true
}